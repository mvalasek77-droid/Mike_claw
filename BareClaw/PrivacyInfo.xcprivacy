<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ── Tracking ──────────────────────────────────────────────────────── -->
    <!-- BareClaw does not track users across apps or websites owned by
         other companies for advertising or data broker purposes.            -->
    <key>NSPrivacyTracking</key>
    <false/>

    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- ── Required-reason APIs ─────────────────────────────────────────── -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!-- UserDefaults — used to persist companion selection, bond score,
             app settings, Her/Him Mode state, onboarding completion flag,
             and user preferences. All data belongs to this app only.       -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File timestamp — FileManager is used to read/write companion
             portrait photos and Hermes memory entries in the app's own
             Documents directory. Timestamps are not shared or transmitted. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string>
            </array>
        </dict>

    </array>

    <!-- ── Data collected ───────────────────────────────────────────────── -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>

        <!-- First name entered during onboarding — used to personalise
             companion responses, stored on-device only.                    -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeName</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Chat messages, journal entries, and interests provided by the
             user — processed by optional third-party AI providers only when
             the user configures their own API key.                         -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherUserContent</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Speech audio — captured by the microphone only when the user
             explicitly activates Him/Her Mode. Audio is processed on-device
             by Apple Speech Recognition and is not recorded or stored.     -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeAudioData</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

    </array>

</dict>
</plist>
